{
  "expo": {
    "name": "RhinoxPay",
    "slug": "RhinoxPay",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/02a74c2a-e7b7-4c2a-80bb-3af677a3b8c4"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020c19"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rhinoxpay.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Allow Rhinox Pay to use Face ID for secure login and transaction verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020c19"
      },
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "backgroundColor": "#020c19"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.rhinoxpay.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "02a74c2a-e7b7-4c2a-80bb-3af677a3b8c4"
      }
    },
    "owner": "hmstech11",
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Rhinox Pay to use Face ID for secure login and transaction verification."
        }
      ],
      "expo-secure-store"
    ]
  }
}
